# Copiá este archivo como .env y completá los valores

# Puerto donde corre la app (por defecto: 3000)
PORT=3000

# Clave secreta para JWT - CAMBIALA por una cadena larga y aleatoria en producción
JWT_SECRET=cambia-esta-clave-por-algo-largo-y-random

# Ruta de la base de datos SQLite
DB_PATH=./theia.db
